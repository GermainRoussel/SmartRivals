# Supabase — copy to .env.local and fill in (Phase 2)
# Public (safe to expose in the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (NEVER expose to the client). Used for seeding / admin tasks:
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (session pooler) — only needed to run migrations
# locally via `node scripts/db-exec.mjs <file.sql>`:
SUPABASE_DB_URL=postgresql://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
